# Database
DATABASE_URL="postgresql://user:password@localhost:5432/doctium"

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# App
NODE_ENV="development"
PORT=3001
ADMIN_PORT=3000

# Firebase (push notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# Zego (video calls)
ZEGO_APP_ID=""
ZEGO_SERVER_SECRET=""
# Zego cloud recording (disabled until explicitly configured)
ZEGO_CLOUD_RECORDING_ENABLED="false"
ZEGO_CLOUD_RECORDING_BASE_URL="https://cloudrecord-api.zego.im"
# JSON object passed to Zego StorageParams. Fill with your approved cloud storage vendor config.
ZEGO_CLOUD_RECORDING_STORAGE_PARAMS=""
ZEGO_CLOUD_RECORDING_FORMAT="mp4"
ZEGO_CLOUD_RECORDING_MAX_IDLE_SECONDS=300
RECORDING_WEBHOOK_SECRET=""
RECORDING_ACCESS_URL_TTL_SECONDS=300
RECORDING_EXPORT_URL_TTL_SECONDS=3600
RECORDING_S3_ACCESS_KEY_ID=""
RECORDING_S3_SECRET_ACCESS_KEY=""
RECORDING_S3_BUCKET=""
RECORDING_S3_REGION=""
# Recording retention defaults. Override per jurisdiction with RECORDING_RETENTION_DAYS_<COUNTRY>.
RECORDING_RETENTION_DEFAULT_DAYS=90
RECORDING_RETENTION_ACTION="ARCHIVE"

# Cloudinary (file storage)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

# Payment Gateways
STRIPE_SECRET_KEY=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
FLUTTERWAVE_SECRET_KEY=""
