# ─── Core ────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/doctium"
NODE_ENV="development"
PORT=3001
ADMIN_PORT=3000

# Public URLs (used in emails, prescription QR links, Paystack callbacks)
API_PUBLIC_URL="http://localhost:3001"
PUBLIC_WEB_URL="http://localhost:3000"
ADMIN_PANEL_URL="http://localhost:3000"

# Local time offset for reminder/cron windows (default +01:00 WAT)
APP_TIMEZONE_OFFSET="+01:00"

# ─── Auth / JWT (required — API refuses to start without these) ──
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-refresh-secret"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Payments (Paystack) ─────────────────────────────────────
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""
# Auto-disburse doctor payouts via Paystack Transfers on approval.
PAYSTACK_AUTO_PAYOUT="false"
# Stripe is planned for non-Nigeria expansion; unused today.
STRIPE_SECRET_KEY=""

# ─── Prescription signing (Ed25519) ──────────────────────────
# Preferred: provide the private key so it never lives in the app DB.
# PEM with literal \n for newlines (same convention as FIREBASE_PRIVATE_KEY).
# Export the current dev key with: node scripts/export-rx-key.cjs
RX_PRIVATE_KEY=""
# If RX_PRIVATE_KEY is unset (dev only), the DB-stored key is encrypted at rest
# with this secret. Required in production only if you keep the DB key path.
RX_KEY_ENCRYPTION_SECRET=""

# ─── Pharmacy partner integration ────────────────────────────
PHARMACY_API_KEY=""
PHARMACY_WEBHOOK_URL=""

# ─── Push notifications (Firebase) ───────────────────────────
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY=""
FIREBASE_CLIENT_EMAIL=""

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Doctium <no-reply@doctium.com>"

# ─── SMS / OTP (Termii) ──────────────────────────────────────
TERMII_API_KEY=""
TERMII_SENDER_ID="Doctium"

# ─── File storage (Cloudinary) ───────────────────────────────
# When unset, uploads fall back to data-URLs stored inline (dev convenience).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── AI (OpenAI: triage "Leenah", scribe, transcription, TTS) ─
OPENAI_API_KEY=""
OPENAI_TRIAGE_MODEL="gpt-4o"
OPENAI_TRANSCRIBE_MODEL="whisper-1"
OPENAI_TTS_MODEL="tts-1"
OPENAI_TTS_VOICE="nova"
TRIAGE_DAILY_LIMIT="20"

# ─── Video calls (Zego) ──────────────────────────────────────
ZEGO_APP_ID=""
ZEGO_SERVER_SECRET=""

# ─── Zego cloud recording (disabled until explicitly configured) ──
ZEGO_CLOUD_RECORDING_ENABLED="false"
ZEGO_CLOUD_RECORDING_BASE_URL="https://cloudrecord-api.zego.im"
ZEGO_CLOUD_RECORDING_MODE="1"
ZEGO_CLOUD_RECORDING_STREAM_TYPE="2"
ZEGO_CLOUD_RECORDING_FORMAT="mp4"
ZEGO_CLOUD_RECORDING_MAX_IDLE_SECONDS=300
ZEGO_CLOUD_RECORDING_IS_TEST="false"
# JSON object passed to Zego StorageParams (your approved cloud storage vendor).
ZEGO_CLOUD_RECORDING_STORAGE_PARAMS=""

# ─── Recording storage + retention ───────────────────────────
RECORDING_WEBHOOK_SECRET=""
RECORDING_ACCESS_URL_TTL_SECONDS=300
RECORDING_EXPORT_URL_TTL_SECONDS=3600
RECORDING_ALLOW_PROVIDER_URL_ACCESS="false"
# Retention defaults. Override per jurisdiction with RECORDING_RETENTION_DAYS_<COUNTRY>.
RECORDING_RETENTION_DEFAULT_DAYS=90
RECORDING_RETENTION_ACTION="ARCHIVE"
# S3-compatible storage for recording assets. RECORDING_S3_* override the AWS_*
# fallbacks when set, so you can keep recording storage separate from other AWS use.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION=""
RECORDING_S3_ACCESS_KEY_ID=""
RECORDING_S3_SECRET_ACCESS_KEY=""
RECORDING_S3_REGION=""
RECORDING_S3_BUCKET=""
