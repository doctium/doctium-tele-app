{
  "name": "doctium",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "eslint apps/api/src",
    "lint:fix": "eslint apps/api/src --fix",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "npm run db:migrate --workspace=@doctium/database",
    "db:studio": "npm run db:studio --workspace=@doctium/database",
    "prepare": "husky",
    "format": "prettier --write ."
  },
  "lint-staged": {
    "apps/api/src/**/*.ts": "eslint --fix",
    "*.{ts,tsx,js,jsx,cjs,mjs,json,md,css}": "prettier --write"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "subset-font": "^2.5.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.61.0"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
