{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev --no-audit --no-fund && npm run db:generate && npm run build --workspace=@doctium/api"
  },
  "deploy": {
    "preDeployCommand": "npx prisma migrate deploy --schema packages/database/prisma/schema.prisma",
    "startCommand": "node apps/api/dist/main",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
