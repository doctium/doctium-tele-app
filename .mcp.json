{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {}
    },
    "prisma-local": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "prisma@latest",
        "mcp"
      ],
      "env": {}
    }
  }
}